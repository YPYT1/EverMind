# Backend mode:
#   cloud  = EverMemOS Cloud API (requires EVERMEMOS_API_KEY)
#   everos = local EverOS HTTP API (recommended for this fork)
EVERMEMOS_BACKEND=everos

# Local EverOS backend. This fork intentionally uses 3378, not 8000.
EVEROS_BASE_URL=http://127.0.0.1:3378
EVEROS_ROOT=
EVEROS_TIMEOUT_SECONDS=180

# EverMind Archive stays a reviewed Chinese project archive.
# propose_basic_memory_update writes candidates only; commit requires confirmed=true.
EVERMIND_ARCHIVE_ROOT=
EVERMIND_ARCHIVE_WRITE_POLICY=candidate
# EVERMIND_ARCHIVE_CANDIDATE_DIR=

# Cloud mode settings. Leave EVERMEMOS_API_KEY empty for local EverOS mode.
EVERMEMOS_API_KEY=
# EVERMEMOS_BASE_URL=https://api.evermind.ai
# EVERMEMOS_API_VERSION=v0
EVERMEMOS_USER_ID=mcp-user

# Optional shared overrides
# EVERMEMOS_ENABLE_CONVERSATION_META=true
# EVERMEMOS_CONVERSATION_SCENE=assistant
# EVERMEMOS_DEFAULT_TIMEZONE=UTC
# EVERMEMOS_SOURCE_RECOVERY_PROBE_TOP_K=100
# EVERMEMOS_SOURCE_RECOVERY_PROBE_CONCURRENCY=4
# EVERMEMOS_LLM_CUSTOM_SETTING_JSON={"boundary":{"provider":"openrouter","model":"openai/gpt-4.1-mini"},"extraction":{"provider":"openrouter","model":"qwen/qwen3-235b-a22b-2507"}}
# EVERMEMOS_USER_DETAILS_JSON={"mcp-user":{"full_name":"Your Name","role":"user"},"assistant":{"full_name":"AI Assistant","role":"assistant"}}

# Optional default space:
# EVERMEMOS_DEFAULT_SPACE=coding:your-project

