# EverMind v2 — Optional Configuration
#
# ALL variables are optional. EverMind works with zero configuration.
# Set only what you need to override from defaults.

# ── Storage ────────────────────────────────────────────────────────────────
# Directory where SQLite databases are stored (one file per project)
# Default: ~/.evermind  (Windows: %USERPROFILE%\.evermind)
# EVERMIND_HOME=~/.evermind

# Override the auto-detected project space (normally inferred from git remote)
# Format: coding:<slug> or any:label
# EVERMIND_DEFAULT_SPACE=coding:my-project

# ── Embedding (optional, improves recall quality) ─────────────────────────
# Install first: uv pip install sqlite-vec sentence-transformers
#
# Local embedding model (downloaded once on first use, ~22MB)
# EVERMIND_EMBED_MODEL=BAAI/bge-small-zh-v1.5
#
# Set to false to disable embedding entirely (FTS5 keyword search only)
# EVERMIND_EMBED_ENABLED=true

# ── LLM Fact Extraction (optional, improves memory quality) ───────────────
# When set, EverMind uses an LLM to extract structured facts from memories.
# Without this, memories are stored as raw text.
#
# EVERMIND_LLM_API_KEY=sk-...
# EVERMIND_LLM_MODEL=gpt-4o-mini
# EVERMIND_LLM_BASE_URL=https://api.openai.com/v1
