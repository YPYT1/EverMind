# EverMind v2 — Optional Configuration
#
# ALL variables are optional. EverMind works with zero configuration.
# Set only what you need to override from defaults.

# ── Storage ────────────────────────────────────────────────────────────────
# Directory where SQLite databases are stored (one file per project)
# Default: ~/.evermind  (Windows: %USERPROFILE%\.evermind)
# EVERMIND_HOME=~/.evermind

# Override the auto-detected project space (normally inferred from git remote)
# Format: coding:<slug> or any:label
# EVERMIND_DEFAULT_SPACE=coding:my-project

# ── SiliconFlow Models (optional, production recall quality) ──────────────
# Keep real keys only in your local .env.
# EVERMIND_SILICONFLOW_API_KEY=sk-...
# EVERMIND_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
#
# Embedding uses OpenAI-compatible /embeddings. Qwen3 is requested at 512
# dimensions to match the default sqlite-vec table.
# EVERMIND_EMBED_PROVIDER=siliconflow
# EVERMIND_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# EVERMIND_EMBED_DIM=512
# EVERMIND_EMBED_WARMUP_ON_START=true
# EVERMIND_EMBED_ENABLED=true
#
# Reranker runs after FTS + dense recall and reorders the top candidates.
# EVERMIND_RERANK_ENABLED=true
# EVERMIND_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
# EVERMIND_RERANK_CANDIDATES=30
#
# LLM is optional and currently used for briefing summaries when enabled.
# EVERMIND_LLM_ENABLED=true
# EVERMIND_LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
# EVERMIND_LLM_BRIEFING_SUMMARY=false

# ── Search / Index Health ─────────────────────────────────────────────────
# Rebuild old FTS rows on startup, useful after installing jieba.
# EVERMIND_AUTO_REINDEX_ON_START=false
# EVERMIND_SENSITIVE_MEMORY_BLOCK=true
